# Email settings to receive contact form submissions
# We recommend using a Gmail account with an "App Password".
# Do not put your real Gmail password here if you have 2-Step Verification enabled.
# Go to Google Account -> Security -> 2-Step Verification -> App Passwords to generate one.
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Admin Panel credentials
ADMIN_USER=admin
ADMIN_PASS=your_admin_password_here
